{
  "annotations": { "list": [] },
  "editable": true,
  "title": "Ignoa 부하테스트",
  "uid": "ignoa-api",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "title": "HikariCP 커넥션 (active / pending) — 풀 잠식",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 15 } } },
      "targets": [
        { "expr": "hikaricp_connections_active{application=\"ignoa-api\"}", "legendFormat": "active", "refId": "A" },
        { "expr": "hikaricp_connections_pending{application=\"ignoa-api\"}", "legendFormat": "pending", "refId": "B" },
        { "expr": "hikaricp_connections_idle{application=\"ignoa-api\"}", "legendFormat": "idle", "refId": "C" }
      ]
    },
    {
      "title": "엔드포인트별 응답시간 p95 — 조회(피해) vs 입찰(가해)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{uri=\"/api/items\", method=\"GET\"}[1m])) by (le))", "legendFormat": "조회 p95 (/api/items)", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{uri=\"/api/items/{itemId}/bids\", method=\"POST\"}[1m])) by (le))", "legendFormat": "입찰 p95 (/bids)", "refId": "B" }
      ]
    },
    {
      "title": "5xx 에러율 — 진짜 장애 시점",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20 } } },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{application=\"ignoa-api\", status=~\"5..\"}[1m]))", "legendFormat": "5xx/s", "refId": "A" }
      ]
    },
    {
      "title": "CPU 사용률 — daisy 자원 경쟁 확인",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "expr": "process_cpu_usage{application=\"ignoa-api\"}", "legendFormat": "app process", "refId": "A" },
        { "expr": "system_cpu_usage{application=\"ignoa-api\"}", "legendFormat": "system(전체)", "refId": "B" }
      ]
    }
  ]
}
